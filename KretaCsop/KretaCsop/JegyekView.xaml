<UserControl x:Class="KretaCsop.JegyekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.8*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource CardDark}" CornerRadius="15" Padding="20" BorderBrush="#333344" BorderThickness="1" Margin="0,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="JEGYEK RÖGZÍTÉSE ÉS SZŰRÉSE" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" Margin="0,0,0,15"/>
                    <StackPanel x:Name="TanariPanel" Visibility="Visible">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="OSZTÁLY" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="OsztalyBox" Height="40" SelectionChanged="OsztalyBox_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="TANTÁRGY" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="TantargyBox" Height="40" SelectionChanged="Szuro_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="DIÁK" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="DiakKivalasztoBox" Height="40" DisplayMemberPath="Nev" SelectionChanged="Szuro_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="DÁTUM" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <DatePicker x:Name="JegyDatumValaszto" Height="40"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="MENTÉS" Width="100" Height="40" VerticalAlignment="Bottom" Click="Button_UjJegyMentese_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <TextBlock Text="ÉRTÉK:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <ComboBox x:Name="JegyBox" Width="80" Height="35">
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="1"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="DiakSzuroPanel" Visibility="Collapsed">
                        <TextBlock Text="TANTÁRGY SZŰRŐ" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5"/>
                        <ComboBox x:Name="DiakTantargyBox" Width="200" HorizontalAlignment="Left" Height="40" SelectionChanged="Szuro_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource CardDark}" CornerRadius="15" Margin="10,0,0,0" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="ÁTLAG" Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="AtlagTextBlock" Text="-" FontSize="50" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource CardDark}" CornerRadius="15" Padding="15" BorderBrush="#333344" BorderThickness="1">
            <DataGrid x:Name="JegyekTablazat" AutoGenerateColumns="False" IsReadOnly="True" ColumnWidth="*" RowHeight="55" Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="OszlopOsztaly" Header="OSZTÁLY" Binding="{Binding Osztaly}" Width="0.5*"/>
                    <DataGridTextColumn x:Name="OszlopDiakNev" Header="DIÁK" Binding="{Binding DiakNeve}" Width="1.5*"/>
                    <DataGridTextColumn Header="TANTÁRGY" Binding="{Binding Tantargy}" Width="1*"/>
                    <DataGridTextColumn Header="JEGY" Binding="{Binding Ertek}" Width="0.4*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DÁTUM" Binding="{Binding Datum}" Width="0.8*"/>

                    <DataGridTemplateColumn x:Name="OszlopTorles" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentRed}" 
                                        FontSize="18" FontWeight="Bold" Click="Button_Torles_Click" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid x:Name="TorlesAblakOverlay" Grid.RowSpan="2" Background="#AA000000" Visibility="Collapsed">
            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" 
                    CornerRadius="15" Width="350" Height="180" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Margin="20">
                    <TextBlock Text="JEGY TÖRLÉSE" Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Biztosan törölni szeretnéd ezt a jegyet?" Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Margin="0,15,0,25"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="MÉGSE" Grid.Column="0" Margin="5" Background="Transparent" Click="Button_Megsem_Click"/>
                        <Button Content="TÖRLÉS" Grid.Column="1" Margin="5" Background="#3D1A1A" Foreground="{StaticResource AccentRed}" BorderBrush="{StaticResource AccentRed}" Click="Button_VeglegesTorles_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>