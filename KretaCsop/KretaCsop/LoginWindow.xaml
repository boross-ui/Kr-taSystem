<Window x:Class="KretaCsop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KRÉTA // TERMINAL ACCESS" Height="800" Width="460" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="{StaticResource BgDark}" CornerRadius="20" BorderBrush="#333344" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Window_MouseDown">
                <Button Content="✕" HorizontalAlignment="Right" Width="45" Background="Transparent" 
                        Foreground="White" BorderThickness="0" Click="Button_Exit_Click" FontSize="16"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="40,0,40,40">
                <TextBlock HorizontalAlignment="Center" FontSize="32" FontWeight="Bold" Foreground="White"><Run Language="hu-hu" Text="KRÉTA SYSTEM"/></TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{StaticResource AccentGreen}" Margin="0,5,0,30"><Run Language="hu-hu" Text="BEJELENTKEZÉSI FELÜLET"/></TextBlock>

                <TabControl Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Border" Margin="0,0,15,25" Padding="10,5">
                                            <ContentPresenter ContentSource="Header" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentGreen}" />
                                                <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="BEJELENTKEZÉS" Foreground="White" FontWeight="Bold">
                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="OM AZONOSÍTÓ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <TextBox x:Name="LoginOmBox" Height="45" Margin="0,0,0,25"/>
                            <TextBlock Text="JELSZÓ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <PasswordBox x:Name="LoginJelszoBox" Height="45" Margin="0,0,0,40"/>
                            <Button Content="BELÉPÉS" Height="50" Click="Button_Bejelentkezes_Click" BorderBrush="{StaticResource AccentGreen}" Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="REGISZTRÁCIÓ" Foreground="White" FontWeight="Bold">
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="TELJES NÉV" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <TextBox x:Name="RegNevBox" Height="40" Margin="0,0,0,15"/>
                            <TextBlock Text="OM AZONOSÍTÓ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <TextBox x:Name="RegOmBox" Height="40" Margin="0,0,0,15"/>
                            <TextBlock Text="SZEREPKÖR" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <ComboBox x:Name="RegSzerepkorBox" Height="40" Margin="0,0,0,15" SelectionChanged="RegSzerepkorBox_SelectionChanged">
                                <ComboBoxItem Content="Diák" IsSelected="True"/>
                                <ComboBoxItem Content="Tanár"/>
                            </ComboBox>
                            <StackPanel x:Name="RegOsztalyPanel">
                                <TextBlock Text="OSZTÁLY" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                                <ComboBox x:Name="RegOsztalyBox" Height="40" Margin="0,0,0,15">
                                    <ComboBoxItem Content="9.A"/>
                                    <ComboBoxItem Content="9.B"/>
                                    <ComboBoxItem Content="9.C"/>
                                    <ComboBoxItem Content="10.A"/>
                                    <ComboBoxItem Content="10.B"/>
                                    <ComboBoxItem Content="10.C"/>
                                    <ComboBoxItem Content="11.A"/>
                                    <ComboBoxItem Content="11.B"/>
                                    <ComboBoxItem Content="11.C"/>
                                    <ComboBoxItem Content="12.A"/>
                                    <ComboBoxItem Content="12.B"/>
                                    <ComboBoxItem Content="12.C"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Text="JELSZÓ" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <PasswordBox x:Name="RegJelszoBox" Height="40" Margin="0,0,0,15"/>
                            <TextBlock Text="JELSZÓ ÚJRA" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="5,0,0,8"/>
                            <PasswordBox x:Name="RegJelszoUjraBox" Height="40" Margin="0,0,0,30"/>
                            <Button Content="FIÓK LÉTREHOZÁSA" Height="50" Click="Button_Regisztracio_Click" BorderBrush="White" Foreground="White"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Grid>
    </Border>
</Window>