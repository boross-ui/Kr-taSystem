<Window x:Class="KretaCsop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KRÉTA" Height="750" Width="1200" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="14">

    <Border Background="{StaticResource BgDark}" CornerRadius="12" BorderBrush="#333344" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource SidebarDark}" MouseLeftButtonDown="Window_MouseDown">
                <TextBlock Text="KRÉTA SYSTEM" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="14"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="-" Width="45" Background="Transparent" Foreground="White" BorderThickness="0" Click="Button_Minimize_Click" FontSize="18"/>
                    <Button Content="✕" Width="45" Background="Transparent" Foreground="White" BorderThickness="0" Click="Button_Close_Click" FontSize="18"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SidebarDark}" BorderBrush="#222233" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,40,0,40">
                            <TextBlock x:Name="ProfilNevText" 
                                       Text="NÉV FRISSÍTÉSE..." 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center" 
                                       FontSize="20"/>
                            <TextBlock x:Name="ProfilSzerepText" 
                                       Text="Szerepkör" 
                                       Foreground="{StaticResource AccentGreen}" 
                                       HorizontalAlignment="Center" 
                                       FontSize="14" 
                                       Margin="0,8,0,0"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="15,0">
                            <StackPanel.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#22222E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="White"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Height" Value="50"/>
                                    <Setter Property="Margin" Value="0,8"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </StackPanel.Resources>

                            <Button Content="ÓRAREND" Click="Button_OrarendBTN_Click"/>
                            <Button Content="JEGYEK" Click="Button_JegyekBTN_Click"/>
                            <Button Content="HIÁNYZÁSOK" Click="Button_HianyzasokBTN_Click"/>
                        </StackPanel>

                        <Button Grid.Row="2" Content="KIJELENTKEZÉS" Height="50" Margin="15,0,15,30" 
                                Background="#3D1A1A" Foreground="{StaticResource AccentRed}" 
                                BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                                Click="Button_Kijelentkezes_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <ContentControl x:Name="MainContent" Margin="25"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>