<UserControl x:Class="KretaCsop.HianyzasokView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardDark}" CornerRadius="15" Padding="25" BorderBrush="#333344" BorderThickness="1" Margin="0,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel x:Name="TanariPanel" Visibility="Visible">
                        <TextBlock Foreground="{StaticResource TextMuted}" FontWeight="Bold" FontSize="11" Margin="0,0,0,15"><Run Text="HIÁNYZÁS NAPLÓZÁSA"/><Run Language="hu-hu" Text=" // IGAZOLÁSA"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="OSZTÁLY" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="OsztalyBox" Height="40" SelectionChanged="OsztalyBox_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="DIÁK" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="DiakKivalasztoBox" Height="40" DisplayMemberPath="Nev" SelectionChanged="Szuro_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="DÁTUM" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <DatePicker x:Name="HianyzasDatumValaszto" Height="40"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <TextBlock Text="HIÁNYZOTT ÓRÁK" FontSize="9" Foreground="{StaticResource AccentGreen}" Margin="5,0,0,5" FontWeight="Bold"/>
                                <ComboBox x:Name="OraBox" Height="40">
                                    <ComboBoxItem Content="1 óra"/>
                                    <ComboBoxItem Content="2 óra"/>
                                    <ComboBoxItem Content="3 óra"/>
                                    <ComboBoxItem Content="4 óra"/>
                                    <ComboBoxItem Content="5 óra"/>
                                    <ComboBoxItem Content="6 óra"/>
                                    <ComboBoxItem Content="7 óra"/>
                                    <ComboBoxItem Content="8 óra"/>
                                </ComboBox>
                            </StackPanel>

                            <Button Grid.Column="4" Content="RÖGZÍTÉS" Width="110" Height="40" VerticalAlignment="Bottom" Click="Button_HianyzasMentese_Click"/>
                        </Grid>
                        <CheckBox x:Name="IgazoltCheckBox" Content="IGAZOLT HIÁNYZÁS" Margin="5,20,0,0" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel x:Name="DiakInformacioPanel" Visibility="Collapsed">
                        <TextBlock Text="HIÁNYZÁSI STATISZTIKA" Foreground="White" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Terminal Monitoring // Saját mulasztások összesítése" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding ElementName=DiakInformacioPanel, Path=Visibility}">
                <Border Background="{StaticResource CardDark}" CornerRadius="15" Width="150" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1" Margin="10,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="IGAZOLT ÓRÁK" Foreground="{StaticResource TextMuted}" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="IgazoltCountText" Text="0" FontSize="52" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource CardDark}" CornerRadius="15" Width="150" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" Margin="15,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="IGAZOLATLAN" Foreground="{StaticResource TextMuted}" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="IgazolatlanCountText" Text="0" FontSize="52" FontWeight="Bold" Foreground="{StaticResource AccentRed}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource CardDark}" CornerRadius="15" Padding="15" BorderBrush="#333344" BorderThickness="1">
            <DataGrid x:Name="HianyzasGrid" AutoGenerateColumns="False" IsReadOnly="True" ColumnWidth="*" RowHeight="55" Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="OszlopDiak" Header="DIÁK NEVE" Binding="{Binding DiakNev}" Width="2*"/>
                    <DataGridTextColumn Header="DÁTUM" Binding="{Binding Datum}" Width="1*"/>
                    <DataGridTextColumn Header="HIÁNYZOTT ÓRÁK" Binding="{Binding OraSzam}" Width="1*"/>
                    <DataGridTextColumn Header="ÁLLAPOT" Binding="{Binding Allapot}" Width="1*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Allapot}" Value="Igazolatlan">
                                        <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Allapot}" Value="Igazolt">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn x:Name="OszlopTorles" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentRed}" 
                                        FontSize="18" FontWeight="Bold" Click="Button_Torles_Click" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid x:Name="TorlesAblakOverlay" Grid.RowSpan="2" Background="#AA000000" Visibility="Collapsed">
            <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" 
                    CornerRadius="20" Width="380" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Margin="25">
                    <TextBlock Text="TÖRLÉS MEGERŐSÍTÉSE" Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="Biztosan törölni szeretnéd ezt a bejegyzést? Ez a művelet nem vonható vissza." 
                               Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,30" FontSize="13"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="MÉGSEM" Grid.Column="0" Margin="5" Height="40" Background="Transparent" Click="Button_Megsem_Click"/>
                        <Button Content="TÖRLÉS" Grid.Column="1" Margin="5" Height="40" Background="#3D1A1A" Foreground="{StaticResource AccentRed}" 
                                BorderBrush="{StaticResource AccentRed}" Click="Button_VeglegesTorles_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>